# =========================
# Groovon Production (Coolify)
# =========================

# Django
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True

# Admin bootstrap
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@your-domain.com
DJANGO_SUPERUSER_PASSWORD=change-this-superuser-password
DJANGO_SUPERUSER_UPDATE_PASSWORD=False

# Celery / Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# TLS safety (keep False in production)
GROOVON_INSECURE_SSL=False

# AI
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Artist/profile data APIs
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
LASTFM_API_KEY=
YOUTUBE_API_KEY=
DISCOGS_TOKEN=
GENIUS_ACCESS_TOKEN=
GOOGLE_KG_API_KEY=
SERPER_API_KEY=
SETLISTFM_API_KEY=
SOUNDCLOUD_CLIENT_ID=

# Event discovery/scraping
SCRAPINGBEE_API_KEY=
BANDSINTOWN_APP_ID=
SEATGEEK_CLIENT_ID=
TICKETMASTER_API_KEY=

# Email verification provider (optional)
# Supported: zerobounce | neverbounce | abstract
EMAIL_VERIFIER_PROVIDER=
ZEROBOUNCE_API_KEY=
NEVERBOUNCE_API_KEY=
ABSTRACT_API_KEY=

# Output storage (optional)
SUPABASE_URL=
SUPABASE_KEY=
